# Copy to .env and adjust as needed.

# Paths
DATA_DIR=./data
MODELS_DIR=./data/models

# yt-dlp
# Set to firefox / chrome / edge to use browser cookies for private content.
# Leave empty to disable.
YTDLP_COOKIES_FROM_BROWSER=

# Job limits (Phase A)
MAX_UPLOAD_BYTES=1073741824
MAX_CONCURRENT_JOBS=1

# Separator
SEPARATOR_USE_CUDA=true
SEPARATOR_USE_FP16=true
SEPARATOR_DEFAULT_MODEL=MDX23C-InstVoc-HQ.ckpt

# FastAPI
API_HOST=127.0.0.1
API_PORT=7860

# CORS — extra browser origins allowed to call the API cross-origin, on top
# of the always-allowed localhost (dev). The DEPLOYED frontend origin MUST be
# listed here or the browser blocks every response. Comma-separated, exact
# scheme+host (no trailing slash, no path). Leave empty for local-only dev.
#   CORS_ALLOW_ORIGINS=https://youmin.site,https://www.youmin.site,https://re-chord.vercel.app
CORS_ALLOW_ORIGINS=

# ── Logging / Observability ─────────────────────────────────
LOG_LEVEL=INFO
# JSON output required for Loki / Datadog / Cloudwatch ingestion.
# Use 'text' for human-friendly dev output.
RECHORD_LOG_FORMAT=text             # text | json
RECHORD_LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
RECHORD_ENV=dev                     # dev | stage | prod
RECHORD_RELEASE=0.3.0

# Sentry (optional). Install `uv pip install "sentry-sdk[fastapi]"`
# and uncomment to enable error tracking + traces.
# SENTRY_DSN=https://<key>@<project>.ingest.sentry.io/<id>
# SENTRY_TRACES_SAMPLE_RATE=0.05

# ── Pre-warm cadence ────────────────────────────────────────
# Prewarm CLAP / PTI / Whisper / madmom on boot so the first
# user-facing job doesn't pay the 30~60s cold-start cost.
RECHORD_PREWARM_AT_BOOT=1
RECHORD_PREWARM_EVERY_MIN=0         # 0 = off; e.g. 30 = re-warm every 30 min

# ── Stability / safety guards ───────────────────────────────
# Runaway guards — generous defaults, raise on slow machines.
RECHORD_YTDLP_TIMEOUT_SEC=600       # max yt-dlp download time
RECHORD_TIMEOUT_SEPARATE=1200       # max per-model separation time
RECHORD_TIMEOUT_TRANSCRIBE=600      # max per-stem transcription time
RECHORD_TIMEOUT_LYRICS=900          # max whisper lyrics time
RECHORD_MAX_PENDING_JOBS=200        # queue backlog cap → HTTP 429 when full
# Set to 1 ONLY on a trusted on-prem deploy that needs to fetch from a
# private media server (disables the SSRF guard).
# RECHORD_ALLOW_PRIVATE_URLS=0
# Set to 1 to keep intermediate work files for debugging a failed job.
# RECHORD_KEEP_WORKDIR=0

# ── Phase B — SaaS storage / database / queue / auth ────────
# All optional in Phase A. Setting any activates the
# corresponding backend module (see docs/deployment.md).

# STORAGE_BACKEND=local              # local | s3 | r2
# RECHORD_S3_BUCKET=rechord-prod
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# DATABASE_URL — PostgreSQL connection. Same string for local Postgres
# and managed services (Supabase / Neon / RDS) — only host/credentials
# differ. The backend reads this at startup; ``backend/app/db/session.py``
# auto-falls-back to Phase-A in-memory mode when this is unset.
#
#   Local (Phase A devs running native Postgres or docker compose):
#     DATABASE_URL=postgresql+asyncpg://rechord:rechord_dev@localhost:5432/rechord
#   Supabase (Phase B):
#     DATABASE_URL=postgresql+asyncpg://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres
#   Neon:
#     DATABASE_URL=postgresql+asyncpg://<user>:<pwd>@<host>.neon.tech/<db>?sslmode=require
#
# After setting, run ONCE to create tables:
#   uv run alembic -c backend/app/db/alembic.ini upgrade head
# DATABASE_URL=postgresql+asyncpg://rechord:rechord_dev@localhost:5432/rechord

# Celery (Phase B distributed queue) — optional; Phase A uses asyncio pool.
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Auth provider (Phase B). Phase A keeps guest mode.
# AUTH_PROVIDER=supabase             # supabase | clerk
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_SECRET=               # only for legacy HS256 projects
# SUPABASE_SERVICE_ROLE_KEY=         # server-side only — NEVER in frontend
# CLERK_JWKS_URL=
# CLERK_AUDIENCE=
# CLERK_ISSUER=

# ── Frontend (Vite) — must be prefixed VITE_ to be exposed to the browser
# Both keys are safe to expose (anon key is RLS-bound). NEVER expose the
# service_role key.
# VITE_AUTH_PROVIDER=supabase
# VITE_SUPABASE_URL=https://<ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=ey...

# Chat (OpenAI worship/music assistant)
# Required to enable /chat/* endpoints. Leave empty to disable the chatbot.
OPENAI_API_KEY=
# Default chat model. Upgrade to gpt-4o for higher Korean/translation quality.
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1200
OPENAI_TEMPERATURE=0.3
# Per-session rate limit (token bucket). 0 disables the limit.
CHAT_RATE_LIMIT_PER_MINUTE=20
CHAT_RATE_LIMIT_BURST=6
CHAT_HISTORY_MAX_MESSAGES=30
CHAT_TOOL_CALLING_ENABLED=true
CHAT_LYRICS_FULL_ON_REQUEST=true
# Optional web-search fallback for songs not in the seed DB.
TAVILY_API_KEY=
WEB_SEARCH_PROVIDER=tavily
